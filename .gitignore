# GreenBlog .gitignore file

# Database files
/data/*.db
/data/greenblog.db
/data/backup/

# Configuration with real values
# Uncomment the line below if you want to exclude the config file after setup
# /includes/config.php

# User uploads (created by installer)
/public_html/uploads/

# Generated static files (created by installer)
/public_html/static/

# Logs
/logs/
*.log

# Temporary files
*.tmp
*.bak
*.swp
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Node.js dependencies
/node_modules/

# Composer dependencies
/vendor/


includes/config.php
.claude